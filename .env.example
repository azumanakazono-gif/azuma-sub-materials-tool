# ─── Google Sheets API 設定 ───────────────────────────────────────────────
# Google Cloud Console > APIとサービス > 認証情報 で取得

# OAuth2 クライアントID（ウェブアプリケーション用）
# 例: 123456789012-abcdefghijklmnopqrstuvwxyz012345.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=

# 対象スプレッドシートのID
# スプレッドシートURL: https://docs.google.com/spreadsheets/d/<ここがID>/edit
VITE_GOOGLE_SPREADSHEET_ID=

# 案件マスターシートの読み込み範囲（A1記法）
VITE_GOOGLE_SHEETS_RANGE=案件マスター!A2:Z

# 発注リスト書き込み先シート名
VITE_GOOGLE_ORDER_SHEET_NAME=発注リスト

# 着工予定リスト（予実同期先）シート名
VITE_GOOGLE_PLAN_SHEET_NAME=着工予定リスト
